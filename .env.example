# =============================================================================
# FC-PLAY Configuration
# =============================================================================
# Copy this to .env and fill in your values.
# fc-play run --env .env

# --- Server ---
HOST=0.0.0.0
PORT=8083
ANTHROPIC_AUTH_TOKEN=

# --- Custom API (Primary way to use Claude) ---
CUSTOM_API_KEY=your-api-key-here
CUSTOM_API_BASE=https://api.anthropic.com
CUSTOM_API_MODEL=claude-sonnet-4-20250514

# --- Provider API Keys ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=

# --- Model Selection ---
# Fallback model
MODEL=custom/claude-sonnet-4-20250514
# Claude tier overrides
MODEL_OPUS=custom/claude-opus-4-20250514
MODEL_SONNET=custom/claude-sonnet-4-20250514
MODEL_HAIKU=custom/claude-haiku-4-20250514

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_CONCURRENT=10

# --- Thinking ---
ENABLE_THINKING=true
ENABLE_OPUS_THINKING=true

# --- Web Tools ---
ENABLE_WEB_SERVER_TOOLS=false

# --- Logging ---
LOG_LEVEL=INFO
FC_LOG_RAW_PAYLOADS=false

# --- Performance ---
CUSTOM_API_TIMEOUT=300
MAX_RETRIES=3
BATCH_SIZE=50
