# ═══════════════════════════════════════════════════════════════════════════
# FC-PLAY Configuration — 20+ Provider Gateway
# ═══════════════════════════════════════════════════════════════════════════
# Copy to ~/.fc-play/.env and fill in your keys.
# fc-play server

# ─── Server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3010
AUTH_TOKEN=

# ─── Primary API Keys ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Community / Multi-Model ──────────────────────────────────────────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
CODESTRAL_API_KEY=
GROQ_API_KEY=
FIREWORKS_API_KEY=
TOGETHER_API_KEY=

# ─── Specialized ──────────────────────────────────────────────────────────
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
CEREBRAS_API_KEY=
KIMI_API_KEY=
WAFER_API_KEY=
OPENCODE_API_KEY=
ZAI_API_KEY=

# ─── Local / Self-hosted ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LLAMACPP_BASE_URL=http://localhost:8080/v1

# ─── Model Routing (provider/model format) ───────────────────────────────
MODEL=custom/claude-sonnet-4-20250514
MODEL_OPUS=custom/claude-opus-4-20250514
MODEL_SONNET=custom/claude-sonnet-4-20250514
MODEL_HAIKU=custom/claude-haiku-4-20250514

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_CONCURRENT=10

# ─── Extended Thinking ────────────────────────────────────────────────────
ENABLE_THINKING=false
ENABLE_OPUS_THINKING=false
ENABLE_SONNET_THINKING=false
ENABLE_HAIKU_THINKING=false

# ─── Web Tools ────────────────────────────────────────────────────────────
ENABLE_WEB_SERVER_TOOLS=false
BLOCK_PRIVATE_NETWORKS=true

# ─── Performance ──────────────────────────────────────────────────────────
MAX_RETRIES=3
TIMEOUT_READ=120
TIMEOUT_WRITE=10
TIMEOUT_CONNECT=30

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RAW_PAYLOADS=false
LOG_SSE_EVENTS=false
